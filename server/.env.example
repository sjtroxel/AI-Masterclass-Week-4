# ChronoQuizzr — Server Environment Variables
# Copy to server/.env and fill in values. Never commit .env.

# Anthropic API key — used by server/services/eventGenerator.ts
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Express server port (defaults to 3001 if not set)
# Railway injects this automatically — do not set it manually in Railway env vars.
PORT=3001

# Production frontend URL — set this to your Vercel deployment URL in Railway env vars.
# Required for CORS to allow the Vercel origin.
FRONTEND_URL=https://your-app.vercel.app
